# Copie para conf.d/weavenbet.conf e ajuste os domínios.
# Depois: docker compose --profile weavenbet up -d

upstream api_weavenbet {
  server api-weavenbet:3000;
}

server {
  listen 80;
  server_name weavenbet.com www.weavenbet.com;

  root /var/www/tenants/weavenbet/front;
  index index.html;

  location / {
    try_files $uri $uri/ /index.html;
  }
}

server {
  listen 80;
  server_name admin.weavenbet.com;

  root /var/www/tenants/weavenbet/admin;
  index index.html;

  location / {
    try_files $uri $uri/ /index.html;
  }
}

server {
  listen 80;
  server_name api.weavenbet.com;

  location / {
    proxy_pass http://api_weavenbet;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 86400;
  }
}
