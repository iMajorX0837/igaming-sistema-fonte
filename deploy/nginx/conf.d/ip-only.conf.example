# Acesso só por IP (sem domínio).
# Site:  http://SEU_IP/
# Admin: http://SEU_IP:8080/
# API:   http://SEU_IP/api/...  (proxy nginx, igual ao Vite local)

upstream api_venuz {
  server api-venuz:3000;
}

server {
  listen 80 default_server;
  server_name _;

  root /var/www/tenants/venuz/front;
  index index.html;

  location /api/ {
    proxy_pass http://api_venuz;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 86400;
  }

  location /aviator/ {
    proxy_pass http://api_venuz;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 86400;
  }

  location /webhook {
    proxy_pass http://api_venuz;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
  }

  location /health {
    proxy_pass http://api_venuz/health;
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}

server {
  listen 8080;
  listen [::]:8080;
  server_name _;

  root /var/www/tenants/venuz/admin;
  index index.html;

  location /api/ {
    proxy_pass http://api_venuz;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 86400;
  }

  location /aviator/ {
    proxy_pass http://api_venuz;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}
