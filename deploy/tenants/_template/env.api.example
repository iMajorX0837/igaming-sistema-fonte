# =============================================================================
# Deploy tenant — PlayFiverAPI
# Renomeie para env.api (sem ponto) na pasta deploy/tenants/SEU_TENANT/
# =============================================================================

# --- Ambiente ---
PORT=3000
NODE_ENV=production
PUBLIC_API_URL=https://api.SEUDOMINIO.com

# --- CORS ---
CORS_ORIGINS=https://SEUDOMINIO.com,https://www.SEUDOMINIO.com,https://admin.SEUDOMINIO.com,https://api.SEUDOMINIO.com,http://SEUDOMINIO.com,http://www.SEUDOMINIO.com,http://admin.SEUDOMINIO.com,http://api.SEUDOMINIO.com

# --- Supabase (1 projeto por tenant) ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Aviator ---
AVIATOR_GAME_ENABLED=true
AVIATOR_PYTHON_PORT=8001
AVIATOR_PYTHON_AUTOSTART=true
AVIATOR_API_ENABLED=false

# --- PlayFivers ---
PLAYFIVER_AGENT_TOKEN=
PLAYFIVER_SECRET_KEY=

# --- MisticPay (opcional — preferir Admin > Financeiro > MisticPay) ---
# MISTICPAY_CI=
# MISTICPAY_CS=
# MISTICPAY_API_URL=https://api.misticpay.com/api
# MISTICPAY_WEBHOOK_SECRET=

# --- BSPay (opcional — preferir Admin > Financeiro > BSPay) ---
# PAYMENT_GATEWAY=misticpay
# BSPAY_CLIENT_ID=
# BSPAY_CLIENT_SECRET=
# BSPAY_SIGNING_KEY=
# BSPAY_WEBHOOK_SECRET=
# BSPAY_API_URL=https://api.bspay.co

# --- VeoPag (opcional — preferir Admin > Gateway de Pagamentos) ---
# VEOPAG_CLIENT_ID=
# VEOPAG_CLIENT_SECRET=
# VEOPAG_WEBHOOK_SECRET=
# VEOPAG_API_URL=https://api.veopag.com

# --- CPF Hub ---
CPFHUB_API_KEY=

# --- Segurança ---
AVIATOR_INTERNAL_SECRET=
AVIATOR_GAME_SESSION_SECRET=
INTERNAL_API_SECRET=

# --- Produção ---
GAME_LAUNCH_MOCK=false
