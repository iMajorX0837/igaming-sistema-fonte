# =============================================================================
# VenuzBET — PlayFiverAPI (servidor Node)
# Copie para .env e preencha:  copy .env.example .env
# =============================================================================

# --- Ambiente ---
PORT=3000
NODE_ENV=production
PUBLIC_API_URL=https://api.SEUDOMINIO.com

# --- Segurança ---
# Pentest local: node scripts/pentest-security.js
# SQL: execute patch_security_hardening.sql e patch_deposit_security.sql no Supabase
CORS_ORIGINS=https://SEUDOMINIO.com,https://www.SEUDOMINIO.com,https://admin.SEUDOMINIO.com

# --- Supabase ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Aviator (clone Spribe) ---
AVIATOR_GAME_ENABLED=true
AVIATOR_PYTHON_PORT=8001
AVIATOR_PYTHON_AUTOSTART=true
AVIATOR_API_ENABLED=false
# AVIATOR_DISCORD_WEBHOOK=
# AVIATOR_RTP_PAGE_ENABLED=false

# --- PlayFivers ---
PLAYFIVER_AGENT_TOKEN=
PLAYFIVER_SECRET_KEY=
# PLAYFIVERS_UPSTREAM_URL=https://api.playfivers.com

# --- MisticPay (PIX depósito/saque) — opcional se configurar no Admin > MisticPay ---
# MISTICPAY_CI=
# MISTICPAY_CS=
# MISTICPAY_API_URL=https://api.misticpay.com/api
# MISTICPAY_WEBHOOK_SECRET=

# --- BSPay (PIX depósito/saque) — opcional se configurar no Admin > BSPay ---
# PAYMENT_GATEWAY=misticpay
# BSPAY_CLIENT_ID=
# BSPAY_CLIENT_SECRET=
# BSPAY_SIGNING_KEY=
# BSPAY_WEBHOOK_SECRET=
# BSPAY_API_URL=https://api.bspay.co

# --- VeoPag (PIX depósito/saque) — opcional se configurar no Admin > Gateway de Pagamentos ---
# VEOPAG_CLIENT_ID=
# VEOPAG_CLIENT_SECRET=
# VEOPAG_WEBHOOK_SECRET=
# VEOPAG_API_URL=https://api.veopag.com

# --- CPF Hub (consulta no cadastro) ---
CPFHUB_API_KEY=

# --- Segurança ---
# Gere: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AVIATOR_INTERNAL_SECRET=
AVIATOR_GAME_SESSION_SECRET=
INTERNAL_API_SECRET=

# --- Dev / testes locais (não usar em produção) ---
GAME_LAUNCH_MOCK=false
# PLAYFIVER_WEBHOOK_SKIP_VALIDATION=true
