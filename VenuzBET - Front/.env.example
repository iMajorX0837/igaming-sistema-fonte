# =============================================================================
# VenuzBET — Front (Vite)
# Copie para .env:  copy .env.example .env
# Dev: copie também .env.development.example → .env.development
# =============================================================================

# --- Produção (mesmo domínio — nginx faz proxy /api → PlayFiverAPI) ---
VITE_API_BASE=/api/supabase
VITE_DEPOSIT_API_BASE=/api/deposit
VITE_PLAYFIVERS_API_BASE=/api/v2
VITE_GAME_LAUNCH_URL=/api/game_launch

# --- URLs absolutas (se front e API estiverem em domínios diferentes) ---
# VITE_API_BASE=https://api.SEUDOMINIO.com/api/supabase
# VITE_DEPOSIT_API_BASE=https://api.SEUDOMINIO.com/api/deposit
# VITE_PLAYFIVERS_API_BASE=https://api.SEUDOMINIO.com/api/v2
# VITE_GAME_LAUNCH_URL=https://api.SEUDOMINIO.com/api/game_launch

# --- Rodadas grátis / roleta (opcional) ---
# VITE_FREE_BONUS_URL=/api/free_bonus
# VITE_PRIZE_WHEEL_GRANT_URL=/api/prize_wheel/grant
